{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "@playwright/test"],
    "strict": true,
    "noEmit": true
  },
  "include": [
    "./playwright.config.ts",
    "./pages/**/*.ts",
    "./support/**/*.ts",
    "./tests/**/*.ts"
  ]
}
